# Copia este archivo como `.env.dev` en esta misma carpeta (`backend/`).
# Está pensado para desarrollo local con `docker compose up -d postgres` (ver `docker-compose.yml`).
#
# Los launch configurations de VS Code/Cursor cargan este archivo y fijan HTTP_PORT por servicio.

CONFIG_SOURCE=env

# Postgres local (usuario/clave/db del compose)
DATABASE_URL=postgres://finexa:finexa@127.0.0.1:5432/finexa?sslmode=disable

# ms-plaid: credenciales sandbox (opcional; sin ellas el servicio arranca pero Plaid responde "no configurado")
PLAID_CLIENT_ID=
# Usa uno de los dos (el código acepta PLAID_SECRET o SANDBOX_SECRET)
PLAID_SECRET=
SANDBOX_SECRET=

# Evita que un AWS_SECRET_ID heredado del sistema fuerce Secrets Manager en local
AWS_SECRET_ID=

# ms-users: token para operaciones internas (header X-MS-Users-Internal-Token). Vacío = deshabilitado.
MS_USERS_INTERNAL_TOKEN=
