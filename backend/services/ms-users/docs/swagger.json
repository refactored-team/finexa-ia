            "get": {
                "description": "Comprueba que el proceso responde y que la base de datos acepta conexión",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/finexa-ia_ms-users_internal_models.HealthResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/finexa-ia_ms-users_internal_models.HealthResponse"
                        }
                    }
                }
            }
        },
        "/v1/users": {
            "get": {
                "description": "Paginación: limit (default 50, max 200), offset. Filtros: email (exacto, case-insensitive), created_from, created_to (RFC3339). include_deleted=true requiere token interno.",
