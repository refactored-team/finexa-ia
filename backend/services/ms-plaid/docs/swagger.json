                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID interno de usuario (FK)",
                        "name": "userId",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Overrides opcionales (webhook, redirect)",
                        "name": "body",
                        "in": "body",
                        "schema": {
