    ],
    "swagger": "2.0",
    "info": {
        "description": "Microservicio Plaid: una conexión activa por usuario. La identidad debe validarse en el API gateway; aquí se usa userId en la ruta.",
        "title": "ms-plaid API",
        "contact": {},
