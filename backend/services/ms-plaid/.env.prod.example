# ms-plaid — entorno local (`make run` hace source de este archivo)
#
# CONFIG_SOURCE=env → solo estas variables; no se usa Secrets Manager.

CONFIG_SOURCE=env

# ── Servicio HTTP (opcional: si lo omites, el código usa 8080) ────────────────
HTTP_PORT=8080

# ── Postgres (si tu docker-compose usa otro usuario/clave, cámbialo aquí) ───
DATABASE_URL=postgresql://finexa:Q%3A1mUA%7C%3FnU%3FrGTrQfxQaSafm2a8d@finexa-infra-mvp-rds-pg.cifuqkcs4ts8.us-east-1.rds.amazonaws.com:5432/finexa_ia_db?sslmode=require

# ── Plaid sandbox (dashboard → Keys): Client ID + Sandbox secret ────────────
# No hace falta PLAID_SECRET; el "Sandbox secret" va en SANDBOX_SECRET.
PLAID_CLIENT_ID=69c9bf6cdce309000dfb523e
SANDBOX_SECRET=b58b264d100a226db46107144cfbd7

# ── Solo cuando despliegues en AWS (quita CONFIG_SOURCE=env en el task) ─────
# AWS_SECRET_ID=nombre-o-arn-del-secreto-json
