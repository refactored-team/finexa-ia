# ms-plaid — entorno local (`make run` hace source de este archivo)
#
# CONFIG_SOURCE=env → solo estas variables; no se usa Secrets Manager.

CONFIG_SOURCE=env

# ── Servicio HTTP (opcional: si lo omites, el código usa 8080) ────────────────
HTTP_PORT=8080

# ── Postgres (si tu docker-compose usa otro usuario/clave, cámbialo aquí) ───
DATABASE_URL=postgresql://finexa:4athhDvyLxUbK3J2x%3FmHuDy9%3AlPT@finexa-infra-mvp-rds-pg.cifuqkcs4ts8.us-east-1.rds.amazonaws.com:5432/finexa_ia_db?sslmode=require

# ── Plaid (dashboard → Keys): Client ID + secret según entorno ───────────────
# No hace falta PLAID_SECRET; en sandbox el "Sandbox secret" va en SANDBOX_SECRET.
# PLAID_ENV: sandbox | production | development (opcional; default sandbox si se omite).
# En production usa PLAID_SECRET con el "Production secret" del dashboard, no el de sandbox.
# PLAID_ENV=production
# Nombre exacto de la Link customization en Plaid Dashboard (Link → Link customization). Opcional; si se omite, Plaid usa "default".
PLAID_LINK_CUSTOMIZATION_NAME=refactored
PLAID_CLIENT_ID=69c9bf6cdce309000dfb523e
SANDBOX_SECRET=b58b264d100a226db46107144cfbd7

# ── Solo cuando despliegues en AWS (quita CONFIG_SOURCE=env en el task) ─────
# AWS_SECRET_ID=nombre-o-arn-del-secreto-json
