# Build from backend/ (monorepo root):
#   docker build --platform linux/amd64 --provenance=false --sbom=false -f services/ms-transactions/Dockerfile.lambda -t ms-transactions:lambda .
# La plataforma va en el CLI (--platform linux/amd64); no uses FROM --platform=... literal (warnings BuildKit).
FROM public.ecr.aws/awsguru/aws-lambda-adapter:0.8.4 AS adapter

FROM golang:1.25-alpine3.21 AS builder
WORKDIR /src
COPY pkg/apiresult ./pkg/apiresult
COPY services/ms-transactions ./services/ms-transactions
WORKDIR /src/services/ms-transactions
ENV GOWORK=off
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o /server ./cmd/server

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
COPY --from=adapter /lambda-adapter /opt/extensions/lambda-adapter
COPY --from=builder /server /server

ENV PORT=8080
ENV AWS_LWA_PORT=8080
ENV READINESS_CHECK_PATH=/ready
ENV AWS_LWA_READINESS_CHECK_PATH=/ready
ENV REMOVE_BASE_PATH=/ms-transactions
ENV AWS_LWA_REMOVE_BASE_PATH=/ms-transactions
ENV ASYNC_INIT=true
ENV AWS_LWA_ASYNC_INIT=true

CMD ["/server"]
