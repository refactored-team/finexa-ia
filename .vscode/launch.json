{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ms-plaid: debug (dev)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/services/ms-plaid/cmd/server",
      "cwd": "${workspaceFolder}/backend/services/ms-plaid",
      "envFile": "${workspaceFolder}/backend/services/ms-plaid/.env.dev",
      "env": {
        "HTTP_PORT": "8080"
      }
    },
    {
      "name": "ms-users: debug (dev)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/services/ms-users/cmd/server",
      "cwd": "${workspaceFolder}/backend/services/ms-users",
      "envFile": "${workspaceFolder}/backend/services/ms-users/.env.dev",
      "env": {
        "HTTP_PORT": "8081"
      }
    }
  ],
  "compounds": [
    {
      "name": "todos los microservicios (dev)",
      "configurations": [
        "ms-plaid: debug (dev)",
        "ms-users: debug (dev)"
      ],
      "stopAll": true
    }
  ]
}
