# Local state files
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Variable files with secrets — never commit these
terraform.tfvars
*.auto.tfvars

# Local backend config (bucket/table names are account-specific)
**/environments/**/backend.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Generated plan files
*.tfplan
